{
  "updaters": [
    "scripts/changelog-updater.js"
  ],
  "types": [
    {
      "type": "feat",
      "section": "✨ Features",
      "hidden": false
    },
    {
      "type": "fix",
      "section": "🐛 Bug Fixes",
      "hidden": false
    },
    {
      "type": "chore",
      "section": "🔧 Chores",
      "hidden": false
    },
    {
      "type": "build",
      "section": "📦 Build",
      "hidden": false
    },
    {
      "type": "style",
      "section": "🎨 Style",
      "hidden": false
    }
  ],
  "commitUrlFormat": "https://gitee.com/passwordgloo/star-read/commit/{{hash}}",
  "compareUrlFormat": "https://gitee.com/passwordgloo/star-read/compare/{{previousTag}}...{{currentTag}}",
  "issueUrlFormat": "https://gitee.com/passwordgloo/star-read/issues/{{id}}"
}